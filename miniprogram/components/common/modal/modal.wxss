.common-modal {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.common-modal__mask {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: rgba(0, 0, 0, 0.45);
  opacity: 1;
  transition-property: opacity;
  transition-timing-function: ease;
}

.common-modal__mask--enter {
  opacity: 0;
}

.common-modal__panel-wrap {
  width: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
  transition: transform 320ms cubic-bezier(0.22, 1, 0.36, 1);
  will-change: transform;
}

.common-modal__panel {
  position: relative;
  width: calc(100% - 72rpx);
  max-width: 640rpx;
  background: #ffffff;
  border-radius: 28rpx;
  box-sizing: border-box;
  padding: 36rpx 28rpx 28rpx;
  opacity: 1;
  transform: translate3d(0, 0, 0) scale(1);
  transition-property: opacity, transform;
  transition-timing-function: cubic-bezier(0.22, 1, 0.36, 1);
  will-change: transform;
}

.common-modal__panel--enter {
  opacity: 0;
  transform: translate3d(0, 20rpx, 0) scale(0.96);
}

.common-modal__header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.common-modal__title-icon {
  display: block;
  margin-right: 10rpx;
  flex: none;
}

.common-modal__title {
  font-size: 36rpx;
  line-height: 1.35;
  color: #FB2C35;
  font-weight: bold;
}

.common-modal__body {
  margin-bottom: 30rpx;
}

.common-modal__description {
  display: block;
  margin-bottom: 18rpx;
  color: #6b7280;
  font-size: 30rpx;
}

.common-modal__textarea {
  width: 100%;
  min-height: 180rpx;
  border: 1px solid #e5e7eb;
  border-radius: 18rpx;
  box-sizing: border-box;
  padding: 20rpx;
  font-size: 30rpx;
  color: #111827;
  background: #f9fafb;
  overflow-y: auto;
}

.common-modal__footer {
  display: flex;
  justify-content: flex-end;
  align-items: center;
}

.common-modal__btn {
  /* min-width: 156rpx; */
  height: 72rpx;
  /* padding: 0 28rpx; */
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  font-size: 30rpx;
  font-weight: 600;
}

.common-modal__btn + .common-modal__btn {
  margin-left: 16rpx;
}

.common-modal__btn--cancel {
  background: #ffffff;
  min-width: 100rpx;
}

.common-modal__btn--confirm {
  background: #f43f5e;
  color: #fff;
  min-width: 200rpx;
}

.common-modal__loading-dot {
  width: 24rpx;
  height: 24rpx;
  margin-right: 10rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(255, 255, 255, 0.45);
  border-top-color: #ffffff;
  box-sizing: border-box;
  animation: common-modal-spin 0.8s linear infinite;
}

.common-modal__btn--disabled {
  opacity: 0.45;
}

.common-modal__btn--hover {
  opacity: 0.85;
}

@keyframes common-modal-spin {
  to {
    transform: rotate(360deg);
  }
}
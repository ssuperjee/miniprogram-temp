.bg-box {
	position: relative;
	overflow: hidden;
}

.bg-box--global {
	position: fixed;
	inset: 0;
	width: 100vw;
	height: 100vh;
	z-index: -1;
}

.bg-box__image {
	position: absolute;
	inset: 0;
	width: 100%;
	height: 100%;
}

.bg-box__content {
	position: relative;
	z-index: 1;
	width: 100%;
	height: 100%;
}
